*/


################################### Penalties ###############################
@penalty CatchMustBeTaken
type process
log_scale True
multiplier 100

################################### Additional Priors ########################
########
## YCS's
#########
@additional_prior Penalty-YCS
type vector_average
parameter process[Recruitment].recruitment_multipliers
k 1
multiplier 1
