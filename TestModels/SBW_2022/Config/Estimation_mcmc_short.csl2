## Short-chain MCMC configuration for tabular-tsv testing
## This is identical to Estimation.csl2 but with a short MCMC chain (10,000 iterations)
## suitable for automated testing. Do NOT use for production runs.

################################### Minimiser ###############################

@mcmc mcmc
type random_walk
start 0
length 10000
keep 100
step_size 0.002
burn_in 1000
proposal_distribution t
adapt_stepsize_method ratio
max_correlation 0.8


################################### Estimates ###############################
## Format for parameter in @estimate block = type[label].parameter
#######
## B0
#######
@estimate B0
type uniform_log
parameter process[Recruitment].b0
lower_bound  30000
upper_bound 800000

## profile B0
@profile B0_profile
parameter process[Recruitment].b0
lower_bound 250000
upper_bound 380000
steps 10

#######################
## Migration/Maturation
#######################
#male
@estimate Migration_male
type uniform
parameter selectivity[MaturationSel_male].v
lower_bound 0.001 0.001 0.001 0.001 0.999
upper_bound 0.999 0.999 0.999 0.999 0.999

#female
@estimate Migration_female
type uniform
parameter selectivity[MaturationSel_female].v
lower_bound 0.001 0.001 0.001 0.001 0.999
upper_bound 0.999 0.999 0.999 0.999 0.999

#######
## YCS
#######
@estimate YCS
parameter process[Recruitment].recruitment_multipliers{1960:2021} 
# YCS 1958:2019
type lognormal
mu 	      	  1 * 62
cv            1.3 * 62
lower_bound   0.001 * 62
upper_bound   100 * 62


#######
## M's (commented out for base model - same as Estimation.csl2)
#######

/*  turn off for base
