!include Population.csl2
!include Sim_observations.csl2
!include Reports.csl2
!include Estimation.csl2

@minimiser adolc
type adolc
tolerance 0.02
iterations 1000
evaluations 2000

@assert obj
type objective_function
value 6910.98
error_type error
tolerance 0.01 # I chose a small tolerance to save computation time with model runners

